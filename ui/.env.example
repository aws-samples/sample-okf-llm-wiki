# Populated from the compute stack's `ui_env` Terraform output before `npm run build`.
VITE_AWS_REGION=us-east-1
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=okf-123456789012.auth.us-east-1.amazoncognito.com
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# Chat side-panel: the chat AgentCore runtime the browser calls directly, the
# OAuth scope the access token must carry, and the model/effort picker catalog
# (base64(JSON), like VITE_HARVEST_MODEL_CATALOG).
VITE_CHAT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/okf_chat-xxxxxxxx
VITE_CHAT_SCOPE=okf-chat/invoke
VITE_CHAT_MODEL_CATALOG=
# Whether the chat's optional read-only SQL tool is deploy-enabled
# (Terraform var.enable_chat_sql). "true" shows the composer's "+" → SQL toggle.
VITE_CHAT_SQL_ENABLED=false
